generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id            String   @id @default(cuid())
  title         String
  description   String
  duration      Int
  genre         String[]
  releaseDate   DateTime
  languages     String[]
  certification String
  posterUrl     String

  rating Float
  votes  Int

  format Format?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shows Show[]

  @@map("movies")
}

model Theater {
  id       String @id @default(cuid())
  name     String
  city     String
  state    String
  location String
  logo     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  screens Screen[]

  @@map("theaters")
}

model Screen {
  id        String @id @default(cuid())
  name      String
  theaterId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  theater Theater @relation(fields: [theaterId], references: [id])

  rows  Row[]
  shows Show[]

  @@map("screens")
}

model Row {
  id       String @id @default(cuid())
  label    String
  screenId String

  screen Screen @relation(fields: [screenId], references: [id])

  seats Seat[]

  @@unique([screenId, label])
  @@map("rows")
}

model Seat {
  id     String @id @default(cuid())
  number Int
  rowId  String

  row Row @relation(fields: [rowId], references: [id])

  showSeats ShowSeat[]

  @@unique([rowId, number])
  @@map("seats")
}

model Show {
  id String @id @default(cuid())

  movieId  String
  screenId String

  startTime DateTime

  format    Format
  audioType String? @default("Dolby Atmos")

  priceMap Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movie  Movie  @relation(fields: [movieId], references: [id])
  screen Screen @relation(fields: [screenId], references: [id])

  showSeats ShowSeat[]

  @@index([movieId])
  @@index([screenId])
  @@index([startTime])
  @@map("shows")
}

model ShowSeat {
  id String @id @default(cuid())

  showId String
  seatId String

  status SeatStatus @default(AVAILABLE)

  show Show @relation(fields: [showId], references: [id])
  seat Seat @relation(fields: [seatId], references: [id])

  @@unique([showId, seatId])
  @@map("show_seats")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  phone         BigInt?        @unique
  role          Role
  activateUser  Boolean        @default(false)
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id     String @id @default(uuid())
  token  String @unique
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

enum Format {
  TWO_D
  THREE_D
  IMAX
  PVR_PXL
}

enum SeatStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum Role {
  admin
  user
}
