generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id            String   @id @default(cuid())
  title         String
  description   String
  duration      String
  genre         String[]
  releaseDate   DateTime
  languages     String[]
  certification String
  posterUrl     String
  rating        Float
  votes         Int
  format        String[] @default(["2D"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  theatres MovieTheater[]

  @@map("movies")
}

model Theater {
  id       String @id @default(cuid())
  name     String
  location String
  logo     String
  city     String
  state    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movies MovieTheater[]

  @@map("theaters")
}

model MovieTheater {
  movieId   String
  theaterId String

  movie   Movie   @relation(fields: [movieId], references: [id])
  theater Theater @relation(fields: [theaterId], references: [id])

  @@id([movieId, theaterId])
  @@map("movie_theaters")
}
