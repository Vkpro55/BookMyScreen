generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id            String   @id @default(cuid())
  title         String
  description   String
  duration      String
  genre         String[]
  releaseDate   DateTime
  languages     String[]
  certification String
  posterUrl     String
  rating        Float
  votes         Int
  format        String[] @default(["2D"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  theatres MovieTheater[]
  shows    Show[]

  @@map("movies")
}

model Theater {
  id       String @id @default(cuid())
  name     String
  location String
  logo     String
  city     String
  state    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movies MovieTheater[]
  shows  Show[]

  @@map("theaters")
}

model MovieTheater {
  movieId   String
  theaterId String

  movie   Movie   @relation(fields: [movieId], references: [id])
  theater Theater @relation(fields: [theaterId], references: [id])

  @@id([movieId, theaterId])
  @@map("movie_theaters")
}

enum Format {
  TWO_D
  THREE_D
  IMAX
  PVR_PXL
}

enum SeatStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

model Show {
  id        String   @id @default(cuid())
  movieId   String
  theaterId String
  location  String
  format    Format
  audioType String?  @default("Dolby Atmos")
  startTime DateTime
  date      DateTime
  priceMap  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movie   Movie   @relation(fields: [movieId], references: [id])
  theater Theater @relation(fields: [theaterId], references: [id])
  rows    Row[]

  @@map("shows")
}

model Row {
  id     String @id @default(cuid())
  row    String
  showId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  show  Show   @relation(fields: [showId], references: [id])
  seats Seat[]

  @@map("rows")
}

model Seat {
  id     String     @id @default(cuid())
  number Int
  status SeatStatus
  rowId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  row Row @relation(fields: [rowId], references: [id])

  @@unique([rowId, number]) // ensures seat number is unique within a row
  @@map("seats")
}
