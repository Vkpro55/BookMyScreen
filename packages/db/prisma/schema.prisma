generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id            String   @id @default(cuid())
  title         String
  description   String
  duration      String
  genre         String[]
  releaseDate   DateTime
  languages     String[]
  certification String
  posterUrl     String
  rating        Float
  votes         Int
  format        String[] @default(["2D"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("movies")
}
